{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ozon Rust Local",
  "version": "0.1.0",
  "identifier": "com.ozonrustsuite.local",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ozon Rust Local",
        "width": 1180,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8790 http://127.0.0.1:17870; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg"],
    "icon": []
  }
}

