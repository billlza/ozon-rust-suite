{
  "framework": "vite",
  "buildCommand": "node scripts/validate-production-env.mjs && pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "local-network-access=(self)"
        }
      ]
    }
  ]
}
