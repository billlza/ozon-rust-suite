VITE_CLOUD_API=https://api-cn.ozon66.com
# The real, working company Nebula OAuth2 server (valid TLS, serves /.well-known/openid-configuration,
# /oauth/authorize, /oauth/token). This is the SAME identity service the SkyBridge Compass apps use,
# so customers get one unified account across all products. NOTE: nebula.skybridge.com is broken
# (self-signed cert + no OAuth endpoints) — do NOT point the portal there.
VITE_NEBULA_BASE_URL=https://auth.nebula-technologies.net
VITE_NEBULA_CLIENT_ID=ozon_rust_suite_portal
VITE_NEBULA_SCOPE=openid profile email offline_access
VITE_ENABLE_NEBULA_OAUTH_ENTRY=1
# Email + password login backed directly by cloud-api. Self-contained (no Supabase / no
# enterprise SSO dependency). For new-account registration, cloud-api must run with
# OZON_SUITE_ALLOW_LOCAL_NEBULA_REGISTRATION=true.
VITE_ENABLE_LOCAL_PASSWORD_AUTH=1
VITE_ENABLE_DIRECT_SKYBRIDGE_AUTH=0
VITE_ENABLE_SKYBRIDGE_PHONE_AUTH=0
VITE_SKYBRIDGE_PHONE_SMS_PROVIDER_READY=0
VITE_DIRECT_AUTH_VERIFICATION_MODE=none
VITE_SKYBRIDGE_SUPABASE_URL=
VITE_SKYBRIDGE_SUPABASE_PUBLISHABLE_KEY=
VITE_SKYBRIDGE_SUPABASE_ANON_KEY=
VITE_ALLOW_LEGACY_SKYBRIDGE_ANON_KEY=
VITE_TURNSTILE_SITE_KEY=
VITE_TURNSTILE_SCRIPT_URL=
