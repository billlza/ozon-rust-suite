# ozon-excel-core relist pipeline — environment template.
# Copy to `.env` and fill in. NEVER commit real secrets (.env is gitignored).
# Nothing here is read by the pure core; only the relist transform + demo_real.py
# (real mode) use these. The --mock demo and the test suite need NONE of them.

# --- Ozon Seller API (demo_real.py real mode: fetch products) -------------- #
# https://api-seller.ozon.ru — Client-Id + Api-Key headers.
OZON_CLIENT_ID=your-ozon-client-id
OZON_API_KEY=your-ozon-api-key

# --- GPT Image 2 image-edit (RelistTransform image restyle) ---------------- #
# POST {OZON_RELIST_IMAGE_API_BASE}/v1/images/edits  (Bearer auth)
OZON_RELIST_IMAGE_API_BASE=https://api.apiyi.com
OZON_RELIST_IMAGE_API_KEY=your-image-edit-api-key
OZON_RELIST_IMAGE_MODEL=gpt-image-2-vip

# --- Relist behaviour ------------------------------------------------------ #
# Host for the restyled images. "litterbox" (default, temporary, no key),
# "local[:dir]" (offline file:// urls), or "r2" (permanent; needs the R2_* vars
# below + boto3).
OZON_RELIST_HOST=litterbox
# On-disk cache dir (key = sha256(model+prompt+source-url)); avoids re-spending.
OZON_RELIST_CACHE=relist_cache
# Override the default white-studio restyle prompt (optional).
# OZON_RELIST_PROMPT=

# --- Cloudflare R2 (only when OZON_RELIST_HOST=r2; pip install boto3) ------- #
# Switching litterbox -> R2 is then a one-config change: set OZON_RELIST_HOST=r2
# and all five vars below.
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket
R2_PUBLIC_BASE=https://your-public-r2-domain.example
